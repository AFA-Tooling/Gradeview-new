API_PORT=8000
PROGRESS_REPORT_PORT=8080
REVERSE_PROXY_LISTEN=0.0.0.0:80
REACT_APP_PROXY_SERVER="http://api:${API_PORT}"
REACT_APP_PORT=3000
ENVIRONMENT=docker

# Updated database URL with encoded password and correct host
GRADESYNC_DATABASE_URL=postgresql://user:password@host:5432/gradesync

# or if connecting via TCP:
# POSTGRES_HOST=your_db_host
# POSTGRES_PORT=5432
# POSTGRES_DB=gradesync
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=your_db_password

# INSTANCE_CONNECTION_NAME is only needed if connecting via Cloud SQL Proxy
# get this from your Google Cloud Console, format is usually project:region:instance
INSTANCE_CONNECTION_NAME=project:region:instance

# --- from website/.env.local ---
# REACT_APP_PROXY_SERVER=http://localhost:8000
# REACT_APP_PORT=3000
FAST_REFRESH=true

# ============================================================================
# GradeSync Specific Configuration
# ============================================================================
# GradeSync Specific Configuration
# ==========================================================================
# GradeSync now uses PostgreSQL as its single data source.

# Gradescope
GRADESCOPE_EMAIL=you@berkeley.edu
GRADESCOPE_PASSWORD=your_gradescope_password

# PrairieLearn
PL_API_TOKEN=your_pl_api_token

# iClicker
ICLICKER_USERNAME=your_name
ICLICKER_PASSWORD=your_iclicker_password
